{
  "name": "@lista-dao/moolah-lending-sdk",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "lint": "pnpm exec eslint \"src/**/*.ts\" --fix",
    "check:types": "pnpm exec tsc --noEmit",
    "test": "pnpm exec vitest run",
    "test:coverage": "pnpm exec vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@lista-dao/moolah-sdk-core": "workspace:^",
    "@morpho-org/blue-sdk": "^1.1.1",
    "viem": "^2.22.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.0",
    "typescript": "^5.2.2",
    "vitest": "^3.2.4"
  }
}
